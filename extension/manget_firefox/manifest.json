{
  "name": "Manget",
  "description": "Download manga chapter from mangadex and some other websites",
  "version": "1.5",
  "manifest_version": 3,
  "icons": {
    "16": "./icons/mangadex_icon.svg",
    "32": "./icons/mangadex_icon.svg",
    "48": "./icons/mangadex_icon.svg",
    "128": "./icons/mangadex_icon.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "contextMenus",
    "downloads"
  ],
  "host_permissions": [
    "https://manget.fly.dev/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "manget@ndtoan96.github.com"
    }
  }
}
